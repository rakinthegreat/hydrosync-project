<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="80dp">

    <!-- THE DYNAMIC BACKGROUND -->
    <ImageView
        android:id="@+id/widget_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/widget_bg_pill_white"
        android:scaleType="fitXY" />

    <!-- NARROW LAYOUT (2x1) -->
    <LinearLayout
        android:id="@+id/widget_narrow_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="24dp"
        android:visibility="visible">

        <TextView
            android:id="@+id/widget_progress_narrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0/2500"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:layout_marginBottom="6dp" />

        <ProgressBar
            android:id="@+id/widget_progress_bar_narrow"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="19dp"
            android:progressDrawable="@drawable/widget_progress_custom"
            android:max="100"
            android:progress="50" />
    </LinearLayout>

    <!-- WIDE LAYOUT (3x1+) -->
    <LinearLayout
        android:id="@+id/widget_wide_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="hydrosync"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginEnd="20dp"
            android:alpha="0.6" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_progress_wide"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0/2500"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:layout_marginBottom="4dp" />

            <ProgressBar
                android:id="@+id/widget_progress_bar_wide"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="19dp"
                android:progressDrawable="@drawable/widget_progress_custom"
                android:max="100"
                android:progress="50" />
        </LinearLayout>
    </LinearLayout>

    <!-- HIDDEN TIMESTAMP (Forces redraw by making RemoteViews unique) -->
    <TextView
        android:id="@+id/widget_timestamp"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone"
        android:text="0" />

    <!-- REFRESH BUTTON (Hidden but clickable) -->
    <ImageButton
        android:id="@+id/widget_refresh_button"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_gravity="top|end"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/stat_notify_sync"
        android:scaleType="centerInside"
        android:alpha="0.0"
        android:contentDescription="Refresh" />

</FrameLayout>
