<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Flutter splash / window themes (do not touch these) -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>

    <!-- HydroSync branded dialog theme (Dusty Ocean palette) -->
    <style name="HydroSyncDialog" parent="Theme.MaterialComponents.Light.Dialog.Alert">
        <!-- Primary brand color for buttons and accents -->
        <item name="colorPrimary">@color/hydro_primary</item>
        <item name="colorPrimaryDark">@color/hydro_primary_dark</item>
        <item name="colorPrimaryVariant">@color/hydro_primary_dark</item>
        <item name="colorOnPrimary">@color/hydro_on_primary</item>
        <!-- Dialog surface: clean light ocean tint -->
        <item name="colorSurface">@color/hydro_surface_light</item>
        <item name="colorOnSurface">@color/hydro_on_surface_light</item>
        <!-- Button text color matches brand -->
        <item name="colorAccent">@color/hydro_primary</item>
        <!-- Rounded corners -->
        <item name="dialogCornerRadius">20dp</item>
    </style>
</resources>
